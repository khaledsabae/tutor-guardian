# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments (huge: ~1.75GB) ────────────────────────────────
.venv/
backend/.venv/
venv/
env/
notebooklm_env/

# ── Secrets / config ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Generated vector indexes (rebuilt from knowledge_base/units/) ───────
knowledge_base/chroma_db/
ops/chroma_data/

# ── Runtime databases (regenerated) ─────────────────────────────────────
*.db
*.sqlite3
ops/sessions.db

# ── Old backups & deprecated data ───────────────────────────────────────
knowledge_base/units_backup/
knowledge_base/units_backup_*/
knowledge_base/data/

# ── Raw source binaries (heavy provenance — not needed to run) ─────────
# Ignore the big binaries, but KEEP extracted/OCR'd .txt sidecars (the usable,
# small derived text that the ingestion pipeline turns into units).
knowledge_base/raw_sources/**/*.pdf
knowledge_base/raw_sources/**/*.png
knowledge_base/raw_sources/**/*.jpg
knowledge_base/raw_sources/**/*.jpeg
knowledge_base/raw_sources/**/*.tif
knowledge_base/raw_sources/**/*.tiff
knowledge_base/raw_sources/**/*.docx
knowledge_base/raw_sources/**/*.epub

# ── OS / editor ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# ── Editor temp files ───────────────────────────────────────────────────
.hermes-tmp.*
*.tmp

# ── Generated fine-tune dataset artifacts (built locally, uploaded to Kaggle) ──
ops/data/qa_dataset.jsonl
ops/data/qa_collected.jsonl
ops/data/qa_*.log
ops/data/qa_*.pid
ops/data/qa_checkpoint.json
ops/data/qa_collected_checkpoint.json

# ── Generated lesson media (AI-generated, ~1.1GB — host on CDN/MinIO, not git) ──
docs/*.mp3
docs/lesson_videos/
docs/lesson_assets/infographics/
