<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config.

  For dev (Phase 1-3): allow cleartext HTTP to localhost / emulator host.
  Note: 10.0.2.2 is the Android emulator alias for the host machine.

  For production: cleartext is disabled (default for HTTPS domains).
  Override at build time via the dart-define API_BASE_URL flag.
-->
<network-security-config>
    <!-- Dev: allow cleartext to localhost + emulator loopback. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
    <!-- Default: HTTPS only (cleartext denied). -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
