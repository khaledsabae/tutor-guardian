# Tutor Guardian — environment configuration
# Copy to .env and adjust. All values have safe local defaults in code.

# ── LLM (local Ollama only — no data leaves the host) ───────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3
OLLAMA_TEMPERATURE=0.3

# ── API ─────────────────────────────────────────────────────────────────────
# Comma-separated CORS origins (the mobile app / web client origins).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Per-IP requests/minute on /api/assistant/* (0 = disabled).
RATE_LIMIT_PER_MINUTE=30

# ── Storage paths (override in containers) ──────────────────────────────────
# CONVERSATIONS_DB=/data/conversations.db
# PROJECT_ROOT=/app
