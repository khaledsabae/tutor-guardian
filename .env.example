# Tutor Guardian — Environment Configuration
# ============================================
# Copy this file to .env and adjust for your setup.
# In Docker production, most variables are set via docker-compose.yml.

# ── Ollama Dual Configuration ─────────────────────────────────────────────────
# The backend supports two Ollama endpoints:
#
#   1. OLLAMA_BASE_URL — Main LLM (cloud/home-server models for generation)
#      Production (Docker): http://ollama:11434
#      Home server dev:     http://localhost:11434 (or http://100.109.163.64:11434)
#
#   2. OLLAMA_LOCAL_BASE_URL — Fallback classifier & fast local models
#      Set this when using a separate home-server for cheap/fast inference.
#      If unset, falls back to OLLAMA_BASE_URL.
#      Home server:          http://100.109.163.64:11434
#      Production (Docker):  (leave unset — OLLAMA_BASE_URL covers it)
#
# In Docker: just set OLLAMA_BASE_URL=http://ollama:11434, leave
# OLLAMA_LOCAL_BASE_URL unset (auto-resolves to OLLAMA_BASE_URL).
#
# On home server: OLLAMA_LOCAL_BASE_URL points to the HP EliteBook Ollama
# while OLLAMA_BASE_URL can point to cloud/localhost for quality models.
# ==============================================================================

# ── Primary / Cloud LLM ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=kimi-k2.6:cloud
OLLAMA_FALLBACK_MODEL=gemma4:31b-cloud

# ── Local / Fast LLM (Home Server via Tailscale) ──────────────────────────────
# Only needed when running dev workstation != home server.
# OLLAMA_LOCAL_BASE_URL=http://100.109.163.64:11434
# OLLAMA_LOCAL_FAST_MODEL=qwen2.5:3b
# OLLAMA_LOCAL_FALLBACK_MODEL=gemma4:e4b

# ── LLM Behaviour ─────────────────────────────────────────────────────────────
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3
OLLAMA_TEMPERATURE=0.3

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30            # AI assistant (/api/assistant/*) budget
RATE_LIMIT_GENERAL_PER_MINUTE=120  # all other /api/* endpoints

# Redis (optional: multi-instance rate limiting). Leave unset for in-memory.
# REDIS_URL=redis://redis:6379/0

# ── Feedback admin ────────────────────────────────────────────────────────────
# REQUIRED for the feedback admin endpoints (list/digest/audio). Fail-closed:
# if unset those endpoints return 403. Generate with: python -c "import secrets;print(secrets.token_urlsafe(32))"
FEEDBACK_ADMIN_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database ──────────────────────────────────────────────────────────────────
# CONVERSATIONS_DB=/data/conversations.db

# ── Marketing & Autoposting ───────────────────────────────────────────────────
# Buffer API access token for automated social media scheduling/posting
BUFFER_ACCESS_TOKEN=
# Telegram Bot Token for posting to Telegram channel
TELEGRAM_BOT_TOKEN=
# Telegram Channel ID (e.g. @tutor_guardian_tips)
TELEGRAM_CHANNEL_ID=
# Production API Base URL (used for hosting marketing images for Buffer to grab)
API_BASE_URL=https://tg-api.alsaba.cloud
