# Keep the build context tiny — never ship venvs / indexes / backups.
.venv/
backend/.venv/
venv/
**/__pycache__/
*.py[cod]
.git/
.githooks/
knowledge_base/chroma_db/
ops/chroma_data/
ops/*.db
*.db
*.sqlite3
knowledge_base/units_backup/
knowledge_base/units_backup_*/
knowledge_base/data/
knowledge_base/raw_sources/
.env
.pytest_cache/
.mypy_cache/

# Media (~2.4GB) is volume-mounted read-only in prod (./docs:/app/docs:ro),
# which shadows the baked COPY docs/. Baking it in just bloats the image and
# fills the VPS disk. Keep the small json/md in docs/ as a dev fallback.
docs/*.mp3
docs/*.mp4
docs/path_videos/
docs/lesson_assets/
